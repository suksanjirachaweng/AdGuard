# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง / Copy to .env and fill in real values

# OpenRouter API key (ฝั่ง server เท่านั้น ห้าม commit)
# สมัครได้ที่ https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-...
# Model ที่ต้องการใช้ (เปลี่ยนได้ตามต้องการ)
# ตัวอย่าง: anthropic/claude-sonnet-4-5, google/gemini-2.5-pro, openai/gpt-4o
# หมายเหตุ: claude-opus-4 เคยพบว่าบางครั้งไม่ตอบตาม JSON schema ที่กำหนด (strict mode)
# แนะนำ claude-sonnet-4-5 ซึ่งเสถียรกว่าในการทดสอบ
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# SERP API (Serper.dev) — ใช้ค้นหาเว็บไซต์ต้องสงสัยอัตโนมัติในหน้า "เฝ้าระวัง"
# สมัครได้ที่ https://serper.dev/ (ไม่ตั้งค่าก็ใช้งานส่วนอื่นได้ปกติ แค่ปุ่ม "ค้นหาตอนนี้" จะใช้ไม่ได้)
SERPER_API_KEY=

# พอร์ตของ "เว็บแอป" (ไม่ใช่พอร์ตของฐานข้อมูล)
PORT=3000

# ===== ระบบ Login =====
# ค่าลับสำหรับเซ็น JWT (ตั้งเป็นสตริงสุ่มยาวๆ ใน production)
JWT_SECRET=ตั้งค่าลับยาวๆตรงนี้
# ผู้ดูแลระบบเริ่มต้น (สร้างให้อัตโนมัติครั้งแรกถ้ายังไม่มี user)
ADMIN_EMAIL=admin@adguard.local
ADMIN_PASSWORD=ตั้งรหัสผ่านผู้ดูแล

# ===== ฐานข้อมูล Supabase Postgres — เลือกแบบใดแบบหนึ่ง =====

# --- แบบ A: ตัวแปรแยก (แนะนำ) ---
# ใส่รหัสผ่านดิบได้เลย แม้มีอักขระพิเศษ (& ? * ฯลฯ) ไม่ต้อง encode
# ค่า host/user เอามาจากปุ่ม Connect → Connection string ใน Supabase
PGHOST=db.xxxxxxxx.supabase.co
PGPORT=5432
PGUSER=postgres
PGDATABASE=postgres
PGPASSWORD=ใส่รหัสผ่านจริงตรงนี้

# --- แบบ B: URL เดียว (ต้อง percent-encode รหัสผ่านถ้ามีอักขระพิเศษ) ---
# เช่นรหัส  a&b?c  ต้องเขียนเป็น  a%26b%3Fc
# DATABASE_URL=postgresql://postgres:ENCODED_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres
